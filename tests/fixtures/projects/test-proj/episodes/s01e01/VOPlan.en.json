      "item_id": "vo-sc01-001",
      "speaker_id": "narrator",
      "text": "At 1:23 a.m., a single button was pressed.",
      "license_type": "commercial_reusable",
      "tts_prompt": {
        "locale": "en",
        "azure_voice": "en-GB-OllieMultilingualNeural",
        "azure_style_degree": 1,
