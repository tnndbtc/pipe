    },
    {
      "item_id": "vo-sc02-003",
      "speaker_id": "narrator",
      "text": "Engineers at the Chernobyl Nuclear Power Plant were preparing for what seemed like a routine safety test.",
      "license_type": "commercial_reusable",
      "tts_prompt": {
        "locale": "en",
        "azure_voice": "en-GB-OllieMultilingualNeural",
        "azure_style_degree": 1,
