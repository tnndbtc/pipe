      },
      "start_sec": 4.724,
      "end_sec": 8.773
    },
    {
      "item_id": "vo-sc01-003",
      "speaker_id": "narrator",
      "text": "Within hours, invisible radiation was drifting across Europe, and decades later scientists still cannot fully explain everything that happened inside that reactor.",
      "license_type": "commercial_reusable",
      "tts_prompt": {
        "locale": "en",
        "azure_voice": "en-GB-OllieMultilingualNeural",
        "azure_style_degree": 1,
        "azure_rate": "0%",
        "azure_pitch": "-5%",
        "azure_break_ms": 600
      },
      "start_sec": 9.073,
      "end_sec": 19.096
    },
    {
      "item_id": "vo-sc01-004",
      "speaker_id": "narrator",
      "text": "This is the story of the night humanity came dangerously close to losing control of nuclear power.",
      "license_type": "commercial_reusable",
      "tts_prompt": {
        "locale": "en",
