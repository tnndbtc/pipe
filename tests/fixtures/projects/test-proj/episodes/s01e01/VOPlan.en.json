      },
      "start_sec": 0.0,
      "end_sec": 4.424
    },
    {
      "item_id": "vo-sc01-002",
      "speaker_id": "narrator",
      "text": "Seconds later, a nuclear reactor exploded.",
      "license_type": "commercial_reusable",
      "tts_prompt": {
        "locale": "en",
        "azure_voice": "en-GB-OllieMultilingualNeural",
        "azure_style_degree": 1,
