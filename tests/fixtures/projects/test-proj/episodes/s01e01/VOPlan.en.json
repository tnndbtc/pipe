    },
    {
      "item_id": "vo-sc02-004",
      "speaker_id": "narrator",
      "text": "They wanted to know whether the turbines could keep producing electricity during a power outage long enough to run the cooling pumps.",
      "license_type": "commercial_reusable",
      "tts_prompt": {
        "locale": "en",
        "azure_voice": "en-GB-OllieMultilingualNeural",
