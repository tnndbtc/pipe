# ── Pipeline runtime outputs ───────────────────────────────────────────────────
# Story input files (user-supplied, never committed)
story*.txt

# Generated project artifacts (written by the pipeline stages)
# Anchored to repo root so tests/fixtures/projects/ is NOT excluded.
/projects/

# Per-run stage logs
stage_logs/

# Variables files written by Stage 0 (runtime-specific, one per story file)
pipeline_vars*.sh

# Long-form direction text written by Stage 0 (runtime-specific)
episode_direction.txt

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
wheels/

# Virtual environments
.venv/
venv/
env/
.env
ENV/

# ── OS ─────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editors ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ── Node.js ────────────────────────────────────────────────────────────────────
node_modules/

# ── Test tooling ────────────────────────────────────────────────────────────────
# Playwright failure artifacts (screenshots, traces, .last-run.json)
test-results/
playwright-report/

# Test fixture exclusions — large or pipeline-generated files inside tests/fixtures/
# that are not needed by the test suite and would bloat the repo.

# Music candidate WAVs (not referenced by any test, ~3MB each)
tests/fixtures/**/cher*__cand*.wav
tests/fixtures/**/cher1_*.wav

# Preview audio outputs (regenerated by the pipeline / API calls during tests)
tests/fixtures/**/preview_audio.wav
tests/fixtures/**/MusicReviewPack/
tests/fixtures/**/SfxPreviewPack/
tests/fixtures/**/MediaPreviewPack/

# ── Playwright MCP ─────────────────────────────────────────────────────────────
# Browser session cache written by the Playwright MCP tool (not source code)
.playwright-mcp/

# ── Misc ───────────────────────────────────────────────────────────────────────
*.log
*.tmp
.env.*
!.env.example
