{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Script",
  "type": "object",
  "required": ["schema_id", "schema_version", "script_id", "project_id", "title", "cast", "scenes"],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "Script",
      "description": "Case-sensitive schema selector used by the pipeline."
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "script_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+-s[0-9]{2}e[0-9]{2}(-script)?$",
      "description": "Format: {project_slug}-sXXeYY-script. The -script suffix is optional for legacy files."
    },
    "project_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Must match the project folder slug exactly. Lowercase letters, digits, and hyphens only."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "genre": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Single canonical genre token, e.g. contemporary-fiction. No spaces or commas."
    },
    "cast": {
      "type": "array",
      "minItems": 1,
      "description": "One entry per named character who speaks or appears in this episode. Defines character attributes used by all downstream stages.",
      "items": {
        "type": "object",
        "required": ["character_id", "gender"],
        "additionalProperties": false,
        "properties": {
          "character_id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Matches speaker_id used in dialogue lines and ShotList vo_speaker_id."
          },
          "gender": {
            "type": "string",
            "enum": ["male", "female", "neutral"],
            "description": "Voice gender: 'male', 'female', or 'neutral' for non-human/disembodied voices. Set explicitly from the story — never infer."
          },
          "role": {
            "type": "string",
            "description": "Short character role description (e.g. 'lead scientist', 'military commander')"
          }
        }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["scene_id", "location", "time_of_day", "actions"],
        "additionalProperties": false,
        "properties": {
          "scene_id": {
            "type": "string",
            "pattern": "^sc[0-9]{2}$",
            "description": "Short scene slug used in downstream filenames, e.g. sc01."
          },
          "location": {
            "type": "string",
            "minLength": 1
          },
          "time_of_day": {
            "type": "string",
            "minLength": 1
          },
          "actions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "required": ["type", "text"],
                  "additionalProperties": false,
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "action"
                    },
                    "text": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Visual action, stage direction, pause, cut, transition, or environmental beat."
                    }
                  }
                },
                {
                  "type": "object",
                  "required": ["type", "speaker_id", "line"],
                  "additionalProperties": false,
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "dialogue"
                    },
                    "speaker_id": {
                      "type": "string",
                      "pattern": "^[a-z0-9-]+$",
                      "description": "Must match one of cast[].character_id exactly."
                    },
                    "line": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Spoken dialogue text used by TTS and VO generation."
                    },
                    "sentence_id": {
                      "type": "string",
                      "description": "Optional legacy field. Not read by TTS or VO pipeline."
                    },
                    "tts": {
                      "type": "object",
                      "description": "Optional per-line Azure TTS rendering hints. Override VoiceCast defaults for this line only.",
                      "additionalProperties": false,
                      "properties": {
                        "style": {
                          "type": "string",
                          "description": "Azure express-as style, e.g. sad, cheerful, angry, whispering, shouting."
                        },
                        "degree": {
                          "type": "string",
                          "description": "Style intensity 0.01–2.0, e.g. '1.5'. Only applies when style is set."
                        },
                        "rate": {
                          "type": "string",
                          "description": "Prosody rate, e.g. '-10%', '+20%', 'slow', 'fast', 'x-slow'."
                        },
                        "pitch": {
                          "type": "string",
                          "description": "Prosody pitch, e.g. '-5%', '+10%', 'low', 'high'."
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}
