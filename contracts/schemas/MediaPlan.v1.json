{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:pipe:MediaPlan.v1",
  "title": "MediaPlan",
  "description": "Confirmed media clip selections per shot, written by the VC editor Media tab and read by render_video.py and media_preview_pack.py.",
  "type": "object",
  "required": ["batch_id", "slug", "episode_id", "version", "selections"],
  "properties": {
    "batch_id":         { "type": "string" },
    "slug":             { "type": "string" },
    "episode_id":       { "type": "string" },
    "version":          { "type": "integer", "minimum": 1 },
    "confirmed_locale": { "type": "string" },
    "selections": {
      "type": "object",
      "description": "Keys are background_id. Values contain per_shot segment lists.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "per_shot": {
            "type": "object",
            "description": "Keys are shot_id. Values contain segment arrays.",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "segments": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["media_type", "url"],
                    "properties": {
                      "media_type":   { "type": "string", "enum": ["image", "video"] },
                      "url":          { "type": "string" },
                      "path":         { "type": "string" },
                      "score":        { "type": ["number", "null"] },
                      "duration_sec": { "type": ["number", "null"] },
                      "hold_sec":     { "type": ["number", "null"] },
                      "start_sec":    { "type": ["number", "null"] },
                      "end_sec":      { "type": ["number", "null"] }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
